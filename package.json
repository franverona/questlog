{
  "name": "questlog",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "db:generate": "turbo run db:generate --filter=@questlog/db",
    "db:migrate": "turbo run db:migrate --filter=@questlog/db",
    "db:seed": "turbo run db:seed --filter=@questlog/db",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --max-warnings=0 --no-warn-ignored"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "npm@11.10.1",
  "engines": {
    "node": ">=24.0.0"
  }
}
