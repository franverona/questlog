{
  "name": "questlog",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "db:migrate": "turbo run db:migrate --filter=@questlog/db",
    "db:seed": "turbo run db:seed --filter=@questlog/db",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "npm@11.10.1",
  "engines": {
    "node": ">=24.0.0"
  }
}
